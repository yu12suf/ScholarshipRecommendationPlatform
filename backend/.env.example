# Server
NODE_ENV=production
PORT=8080
SERVER_URL=https://your-app.onrender.com
FRONTEND_URL=https://your-frontend.onrender.com
BACKEND_URL=https://your-app.onrender.com
HOST_URL=https://your-app.onrender.com
PRODUCTION_URL=https://your-app.onrender.com

# Database (PostgreSQL - Neon)
DB_HOST=your-neon-host.neon.tech
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# Auth
JWT_SECRET=your-secure-jwt-secret-min-32-chars
REFRESH_TOKEN_SECRET=your-secure-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=7d

# Google Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourapp.com

# Google Generative AI (Gemini)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Redis (optional - for queue processing)
REDIS_HOST=your-redis-host
REDIS_PORT=63790
REDIS_PASSWORD=your-redis-password

# Chapa Payment (optional)
CHAPA_SECRET_KEY=
CHAPA_SECRET_HASH=

# Pricing
MONTHLY_PRICE_IN_ETB=0
QUARTERLY_PRICE_IN_ETB=0
ANNUAL_PRICE_IN_ETB=0
SEMIANNUAL_PRICE_IN_ETB=0

# Chat
MAX_CHAT_USAGE=10

# Assessment Queue
ASSESSMENT_USE_QUEUE=false